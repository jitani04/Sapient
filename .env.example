APP_NAME=Sapient
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot_db
LLM_API_KEY=your_google_ai_api_key
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=60
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=768

SYSTEM_PROMPT=You are a helpful assistant.
KEEPALIVE_SECONDS=15
UPLOAD_MAX_BYTES=10485760
UPLOAD_URL_EXPIRES_SECONDS=300
PREVIEW_URL_EXPIRES_SECONDS=3600

# S3-compatible object storage (Cloudflare R2 / AWS S3 / etc.)
S3_BUCKET=its-materials
S3_REGION=auto
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RAG_TOP_K=4
RAG_CANDIDATE_K=50
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_RERANKER_ENABLED=false
RAG_RERANKER_TIMEOUT_SECONDS=8
LANGSEARCH_API_KEY=
LANGSEARCH_API_BASE_URL=https://api.langsearch.com
LANGSEARCH_RERANK_MODEL=langsearch-reranker-v1
WEB_SEARCH_ENABLED=true
WEB_SEARCH_RESULT_COUNT=5
WEB_SEARCH_TIMEOUT_SECONDS=8
ENABLE_FEEDBACK_PREFERENCES=false
ENABLE_PREFERENCE_MEMORY=false
PREFERENCE_SUMMARY_MAX_FEEDBACK_ITEMS=25
PREFERENCE_MEMORY_TOP_K=3
PROMPT_VERSION=default

JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
OPENAI_TTS_API_KEY=
OPENAI_TTS_VOICE=nova
# Required only if users may pick Claude as their chat model.
ANTHROPIC_API_KEY=
# Required only if users may pick GPT as their chat model. Falls back to OPENAI_TTS_API_KEY
# if not set, so a single OpenAI key can serve both chat and TTS.
OPENAI_API_KEY=
EVAL_OPENAI_API_KEY=
EVAL_JUDGE_MODEL=gpt-4o
EVAL_JUDGE_EMBEDDING_MODEL=text-embedding-3-small
EVAL_TUTORING_SOURCE=tutorbench
EVAL_TUTORING_DATASET=ScaleAI/TutorBench
EVAL_TUTORING_SAMPLE_SIZE=100
EVAL_TUTORING_INCLUDE_MULTIMODAL=0
PEXELS_API_KEY=
# YouTube Data API v3 key. Used by the find_resource tool to fetch video tutorials.
# Get one at https://console.cloud.google.com (enable "YouTube Data API v3").
YOUTUBE_API_KEY=
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Observability
METRICS_ENABLED=true
JSON_LOGS=true
APP_VERSION=dev
# OTLP HTTP endpoint. Leave blank to disable trace export. Metrics are still scrapable from /metrics.
# Grafana Cloud:  https://otlp-gateway-prod-<region>.grafana.net/otlp
# Honeycomb:      https://api.honeycomb.io
# Local Jaeger:   http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# Comma-separated header pairs, e.g. "Authorization=Basic <base64>" for Grafana Cloud,
# or "x-honeycomb-team=<api-key>" for Honeycomb. Leave blank for unauthenticated collectors.
OTEL_EXPORTER_OTLP_HEADERS=
# Print spans to stdout for local debugging
OTEL_CONSOLE_TRACES=false

# Rate limits (requests per minute, per user; auth uses per IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_STT_PER_MIN=20
RATE_LIMIT_TTS_PER_MIN=30
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_SUMMARY_PER_MIN=10
RATE_LIMIT_UPLOAD_PER_MIN=30
